#!/bin/bash
# This wrapper script is supposed to be visible in ps -a resp. ps -u `id -u` to make
# it easy to kill it (by a script or manually)

PIDS=()
function finish {
    EXIT_CODE=$?
    kill "${PIDS[@]}" >/dev/null 2>&1
    exit $EXIT_CODE
}
trap finish SIGINT SIGTERM EXIT

exhibit-track-n-truck-api-server &
PID_API_SERVER=$!
PIDS+=("$PID_API_SERVER")

# The server takes some time to start up, so we wait a bit before starting the UIs,
# to increase the chances that the server is ready by the time they start and thus
# avoid error messages about the server being unavailable.
# Introduces a race condition, but in case this fails, the clients will try to reconnect
# a later (showing an error message in the meantime).
sleep 1

exhibit-track-n-truck-trucker &
PID_TRUCKER_UI=$!
PIDS+=("$PID_TRUCKER_UI")

# To make the tracker UI more likely to become the foreground window on startup,
# we start it a bit later than the trucker UI.
# This introduces a race condition, but in practice it should be good enough,
# because in case it fails, the worst that can happen is that user needs to click
# into the the tracker UI once to bring it to the foreground, which is not a big deal.
sleep 1

exhibit-track-n-truck-tracker &
PID_TRACKER_UI=$!
PIDS+=("$PID_TRACKER_UI")

# Wait for the exhibit to finish or until the signal trap is triggered
wait -n "${PIDS[@]}"
