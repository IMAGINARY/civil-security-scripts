#!/bin/bash
# This wrapper script is supposed to be visible in ps -a resp. ps -u `id -u` to make
# it easy to kill it (by a script or manually)

PIDS=""
function finish {
    EXIT_CODE=$?
    kill $PIDS >/dev/null 2>&1
    exit $EXIT_CODE
}
trap finish SIGINT SIGTERM EXIT

APP_DIR="/opt/skills-and-resources"
TOKEN_READER_DIR="$APP_DIR/tools/token-reader"


# Configuration
CIVIL_SECURITY_SKILLS_AND_RESOURCES_INVENTORY_TOKEN_READER_DEFAULT="ACS ACR122U 00 00"
if [[ -z "${CIVIL_SECURITY_SKILLS_AND_RESOURCES_INVENTORY_TOKEN_READER}" ]]; then
  echo "CIVIL_SECURITY_SKILLS_AND_RESOURCES_INVENTORY_TOKEN_READER environment variable not set. Using default value: ${CIVIL_SECURITY_SKILLS_AND_RESOURCES_INVENTORY_TOKEN_READER_DEFAULT}"
  export CIVIL_SECURITY_SKILLS_AND_RESOURCES_INVENTORY_TOKEN_READER="$CIVIL_SECURITY_SKILLS_AND_RESOURCES_INVENTORY_TOKEN_READER_DEFAULT"
else
  echo "Using CIVIL_SECURITY_SKILLS_AND_RESOURCES_INVENTORY_TOKEN_READER environment variable. Value: ${CIVIL_SECURITY_SKILLS_AND_RESOURCES_INVENTORY_TOKEN_READER}"
fi

CIVIL_SECURITY_SKILLS_AND_RESOURCES_CHALLENGE_TOKEN_READER_DEFAULT="ACS ACR122U 01 00"
if [[ -z "${CIVIL_SECURITY_SKILLS_AND_RESOURCES_CHALLENGE_TOKEN_READER}" ]]; then
  echo "CIVIL_SECURITY_SKILLS_AND_RESOURCES_CHALLENGE_TOKEN_READER environment variable not set. Using default value: ${CIVIL_SECURITY_SKILLS_AND_RESOURCES_CHALLENGE_TOKEN_READER_DEFAULT}"
  export CIVIL_SECURITY_SKILLS_AND_RESOURCES_CHALLENGE_TOKEN_READER="$CIVIL_SECURITY_SKILLS_AND_RESOURCES_CHALLENGE_TOKEN_READER_DEFAULT"
else
  echo "Using CIVIL_SECURITY_SKILLS_AND_RESOURCES_CHALLENGE_TOKEN_READER environment variable. Value: ${CIVIL_SECURITY_SKILLS_AND_RESOURCES_CHALLENGE_TOKEN_READER}"
fi

# Launch the token reader daemon in the background
# Do not use npm scripts here, because they don't forward signals properly,
# which causes problems stopping the server gracefully.
cd "$TOKEN_READER_DIR" || exit 1
TSX=$(npx --no-install -p tsx which tsx)
export PATH="$(dirname "$TSX"):$PATH"
tsx src/index.ts serve \
  --no-buzzer \
  -i "${CIVIL_SECURITY_SKILLS_AND_RESOURCES_INVENTORY_TOKEN_READER}" \
  -c "${CIVIL_SECURITY_SKILLS_AND_RESOURCES_CHALLENGE_TOKEN_READER}" \
  &
PID=$!
PIDS="$PIDS $PID"

# Wait for the token reader to finish or until the signal trap is triggered
wait -n $PIDS
exit $?
