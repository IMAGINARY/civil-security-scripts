#!/bin/bash
# This wrapper script is supposed to be visible in ps -a resp. ps -u `id -u` to make
# it easy to kill it (by a script or manually)

PIDS=""
function finish {
    EXIT_CODE=$?
    kill $PIDS >/dev/null 2>&1
    exit $EXIT_CODE
}
trap finish SIGINT SIGTERM EXIT

SCRIPT_DIR="$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")"
APP_DIR="/opt/holo-quest"
APP_DIST_DIR="$APP_DIR/dist"
USER_OVERLAY_DIR="$HOME/.config/holo-quest/overlay"

mkdir -p "$USER_OVERLAY_DIR"
touch "$USER_OVERLAY_DIR/settings.yml"

PRELOAD_SCRIPT="$SCRIPT_DIR/holo-quest/preload.js"

# Overlay the user-supplied config on top of the exhibit-supplied config and
# launch the exhibit frontend in the background
run-with-overlay \
    --lowerdir "$APP_DIST_DIR" \
    --lowerdir "$USER_OVERLAY_DIR" \
    -- \
    kiosk-browser $KIOSK_OPTS \
        --cover-displays "0,1" \
        --disable-drag \
        --disable-selection \
        --overflow=hidden \
        --reload-idle "$((3 * 60))" \
        --reload-unresponsive 60 \
        --preload "$PRELOAD_SCRIPT" \
        --serve "$APP_DIST_DIR" \
        "index.html?${CIVIL_SECURITY_HOLO_QUEST_QUERY_STRING}" \
&

PID_UI=$!
PIDS="$PIDS $PID_UI"

# Wait for the exhibit to finish or until the signal trap is triggered
wait -n $PIDS
exit $?
