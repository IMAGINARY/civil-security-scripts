#!/bin/bash

set -e

COMMITISH="be90183f97b2854099e73d9a1d0a19cd44b094c6"
REPO_URL="https://github.com/IMAGINARY/skills-and-resources"
INSTALL_DIR="/opt/skills-and-resources"

"${BASH_SOURCE%/*}/../internal/install-source-from-git" "$COMMITISH" "$REPO_URL" "$INSTALL_DIR"

apt update
apt install -yq --no-install-recommends \
  build-essential \
  libacsccid1 \
  libpcsclite-dev \
  pcscd \
  pcsc-tools \
  "" # dummy entry to terminate the list

# Build the project
cd "$INSTALL_DIR" || exit 1
corepack enable
corepack use npm@11
npm install
npm run build
corepack disable
