#!/bin/bash

set -e

COMMITISH="681960d0612d7ebbf35de2ff991c65353fa5cb91"
REPO_URL="https://github.com/IMAGINARY/track-n-truck"
INSTALL_DIR="/opt/track-n-truck"

"${BASH_SOURCE%/*}/../internal/install-source-from-git" "$COMMITISH" "$REPO_URL" "$INSTALL_DIR"

# Build the project
cd "$INSTALL_DIR" || exit 1
corepack enable
corepack use npm@11
npm install
npm run build
corepack disable
