#!/bin/bash

set -e

COMMITISH="fffa6c992b90c646c30eaa6789367e36cc9eb23c"
REPO_URL="https://github.com/manueleigen/awareness-map"
INSTALL_DIR="/opt/awareness-map"

"${BASH_SOURCE%/*}/../internal/install-source-from-git" "$COMMITISH" "$REPO_URL" "$INSTALL_DIR"

# Build the project
cd "$INSTALL_DIR" || exit 1
corepack enable
corepack use npm@11
npm install
npm run build:all
corepack disable
